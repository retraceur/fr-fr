#: wp-includes/js/dist/editor.js:54620
msgid "Review settings, such as visibility and tags."
msgstr "Revoir les réglages tels que la visibilité et les étiquettes."

#: wp-includes/js/dist/editor.js:54635 wp-includes/js/dist/editor.js:54639
msgid "Appearance"
msgstr "Apparence"

#: wp-includes/js/dist/editor.js:54640
msgid "Customize the editor interface to suit your needs."
msgstr "Personnaliser l’interface de l’éditeur pour l’adapter à vos besoins."

#: wp-includes/js/dist/editor.js:54654
msgid "Access all block and document tools in a single place."
msgstr ""
"Accéder à tous les blocs et aux outils du document depuis une endroit unique."

#: wp-includes/js/dist/editor.js:54674
msgid ""
"Reduce visual distractions by hiding the toolbar and other elements to focus "
"on writing."
msgstr ""
"Réduire les distractions visuelles en masquant la barre d’outils et d’autres "
"éléments pour se concentrer sur la rédaction."

#: wp-includes/js/dist/editor.js:54685
msgid "Highlights the current block and fades other content."
msgstr "Met en lumière le bloc actuel et occulter les autres contenus."

#: wp-includes/js/dist/editor.js:54698
msgid "Accessibility"
msgstr "Accessibilité"

#: wp-includes/js/dist/editor.js:54703
msgid "Navigation"
msgstr "Navigation"

#: wp-includes/js/dist/editor.js:54704
msgid "Optimize the editing experience for enhanced control."
msgstr "Optimiser l’expérience d’édition pour un contrôle amélioré."

#: wp-includes/js/dist/editor.js:54712
msgid ""
"Keeps the text cursor within blocks while navigating with arrow keys, "
"preventing it from moving to other blocks and enhancing accessibility for "
"keyboard users."
msgstr ""
"Maintient le curseur de texte à l’intérieur des blocs alors que vous "
"naviguez à l’aide des touches fléchées, cela permet d’éviter des "
"déplacements vers d’autres blocs et améliore l’accessibilité des "
"utilisateur·rice·s de clavier."

#: wp-includes/js/dist/editor.js:54715
msgid "Contain text cursor inside block"
msgstr "Contenir le curseur du text à l’intérieur du bloc"

#: wp-includes/js/dist/editor.js:54731
msgid "Show button text labels"
msgstr "Montrer les libellés de bouton"

#: wp-includes/js/dist/editor.js:54732
msgid "Show text instead of icons on buttons across the interface."
msgstr ""
"Afficher du texte au lieu d’icônes sur les boutons pour toute l’interface."

#: wp-includes/js/dist/editor.js:54745
msgid "Inserter"
msgstr "Inséreur"

#: wp-includes/js/dist/editor.js:54750
msgid "Adds a category with the most frequently used blocks in the inserter."
msgstr ""
"Ajoute une catégorie contenant les blocs les plus fréquemment utilisés par "
"l’inséreur."

#: wp-includes/js/dist/editor.js:54753
msgid "Show most used blocks"
msgstr "Montrer les blocs les plus utilisés"

#: wp-includes/js/dist/editor.js:54759
msgid "Manage block visibility"
msgstr "Gérer la visibilité des blocs"

#: wp-includes/js/dist/editor.js:54760
msgid ""
"Disable blocks that you don't want to appear in the inserter. They can "
"always be toggled back on later."
msgstr ""
"Désactiver les blocs que vous ne souhaitez pas voir apparaître dans "
"l’inséreur. Ils peuvent toujours être réactivés par la suite."

#: wp-includes/js/dist/editor.js:54775
msgid "Customize options related to the media upload flow."
msgstr "Personnaliser les options relatives au flux de chargement des médias."

#: wp-includes/js/dist/editor.js:54784
msgid "Compress media items before uploading to the server."
msgstr "Compresser les éléments de media avant leur chargement sur le serveur."

#: wp-includes/js/dist/editor.js:54787
msgid "Pre-upload compression"
msgstr "Compression avant chargement"

#: wp-includes/js/dist/editor.js:54795
msgid "Require approval step when optimizing existing media."
msgstr ""
"Rendre obligatoire une étape d’approbation lors de l’optimisation des médias "
"existants."

#: wp-includes/js/dist/editor.js:54798
msgid "Approval step"
msgstr "Étape d’approbation"

#: wp-includes/js/dist/editor.js:54907
msgid "Post Date"
msgstr "Date de l’article"

#: wp-includes/js/dist/editor.js:54912
msgid "Post Modified Date"
msgstr "Date de modification de l’article"

#: wp-includes/js/dist/editor.js:54917
msgid "Post Link"
msgstr "Lien de l’article"

#: wp-includes/js/dist/editor.js:55123
msgid "Term ID"
msgstr "Identifiant du terme"

#: wp-includes/js/dist/editor.js:55148
msgid "Parent ID"
msgstr "Identifiant du parent"

#: wp-includes/js/dist/editor.js:55153
msgid "Count"
msgstr "Décompte"
