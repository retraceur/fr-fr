msgctxt "Scale option for dimensions control"
msgid "Fill"
msgstr "Remplir"

#: wp-includes/js/dist/block-editor.js:67186
msgid "Fill the space by stretching the content."
msgstr "Remplir l’espace en étirant le contenu."

#: wp-includes/js/dist/block-editor.js:67190
msgctxt "Scale option for dimensions control"
msgid "Contain"
msgstr "Contenir"

#: wp-includes/js/dist/block-editor.js:67191
msgid "Fit the content to the space without clipping."
msgstr "Adapter le contenu à l’espace sans coupure."

#: wp-includes/js/dist/block-editor.js:67195
msgctxt "Scale option for dimensions control"
msgid "Cover"
msgstr "Couvrir"

#: wp-includes/js/dist/block-editor.js:67196
msgid "Fill the space by clipping what doesn't fit."
msgstr "Remplir l’espace en découpant ce qui dépasse."

#: wp-includes/js/dist/block-editor.js:67200
msgctxt "Scale option for dimensions control"
msgid "None"
msgstr "Aucun"

#: wp-includes/js/dist/block-editor.js:67201
msgid ""
"Do not adjust the sizing of the content. Content that is too large will be "
"clipped, and content that is too small will have additional padding."
msgstr ""
"Ne pas ajuster le dimensionnement du contenu. Le contenu trop large sera "
"découpé, et le contenu trop étroit aura des marges internes additionnelles."

#: wp-includes/js/dist/block-editor.js:67207
msgctxt "Scale option for dimensions control"
msgid "Scale down"
msgstr "Réduire"

#: wp-includes/js/dist/block-editor.js:67208
msgid ""
"Scale down the content to fit the space if it is too big. Content that is "
"too small will have additional padding."
msgstr ""
"Réduire le contenu pour qu’il s’ajuste à l’espace s’il est trop gros. Le "
"contenu qui est trop étroit aura des marges internes additionnelles."

#: wp-includes/js/dist/block-editor.js:67231
#: wp-includes/js/dist/block-editor.js:67239
msgctxt "Image scaling options"
msgid "Scale"
msgstr "Mettre à l’échelle"

#: wp-includes/js/dist/block-editor.js:67460
