#: wp-includes/js/dist/block-library.js:11147
msgid ""
"// A “block” is the abstract term used\n"
"// to describe units of markup that\n"
"// when composed together, form the\n"
"// content or layout of a page.\n"
"registerBlockType( name, settings );"
msgstr ""
"// Un « bloc » est le terme abstrait utilisé\n"
"// pour décrire les unités de balisage qui\n"
"// lorsqu’arrangés ensemble, forme le\n"
